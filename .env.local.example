# Copy this file to `.env.local` and fill in your values (never commit `.env.local`).
# NASA: https://api.nasa.gov/ — DEMO_KEY works with strict rate limits.
NASA_API_KEY=your_nasa_api_key_here

# Telegram: create a bot with @BotFather, then get your chat id (e.g. from getUpdates).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
